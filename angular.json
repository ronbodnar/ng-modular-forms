{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "behavior": {
      "projectType": "library",
      "root": "projects/behavior",
      "sourceRoot": "projects/behavior/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/behavior/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/behavior/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/behavior/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/behavior/tsconfig.spec.json"
          }
        }
      }
    },
    "core": {
      "projectType": "library",
      "root": "projects/core",
      "sourceRoot": "projects/core/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/core/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/core/tsconfig.spec.json"
          }
        }
      }
    },
    "input": {
      "projectType": "library",
      "root": "projects/input",
      "sourceRoot": "projects/input/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/input/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/input/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/input/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/input/tsconfig.spec.json"
          }
        }
      }
    },
    "material": {
      "projectType": "library",
      "root": "projects/material",
      "sourceRoot": "projects/material/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/material/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/material/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/material/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/material/tsconfig.spec.json"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}

{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "behavior": {
      "projectType": "library",
      "root": "projects/behavior",
      "sourceRoot": "projects/behavior/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/behavior/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/behavior/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/behavior/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/behavior/tsconfig.spec.json"
          }
        }
      }
    },
    "core": {
      "projectType": "library",
      "root": "projects/core",
      "sourceRoot": "projects/core/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/core/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/core/tsconfig.spec.json"
          }
        }
      }
    },
    "input": {
      "projectType": "library",
      "root": "projects/input",
      "sourceRoot": "projects/input/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/input/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/input/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/input/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/input/tsconfig.spec.json"
          }
        }
      }
    },
    "material": {
      "projectType": "library",
      "root": "projects/material",
      "sourceRoot": "projects/material/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/material/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/material/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/material/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/material/tsconfig.spec.json"
          }
        }
      }
    },
    "examples": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/examples",
      "sourceRoot": "projects/examples/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/examples",
            "index": "projects/examples/src/index.html",
            "browser": "projects/examples/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/examples/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/examples/public"
              }
            ],
            "styles": [
              "projects/examples/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "examples:build:production"
            },
            "development": {
              "buildTarget": "examples:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/examples/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/examples/public"
              }
            ],
            "styles": [
              "projects/examples/src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
